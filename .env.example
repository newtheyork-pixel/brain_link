# StillMe runs fully on-device by default (Ollama on localhost).
# Set these ONLY if you have a bigger GPU box to develop against.
#
# Never commit the real values. Ollama has no authentication — a URL in a public
# repo is an open GPU for anyone who reads the source.

# STILLME_REMOTE_HOST=https://your-gpu-box.example.com
# STILLME_REMOTE_MODEL=qwen3:14b
